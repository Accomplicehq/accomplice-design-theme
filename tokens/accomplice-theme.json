{
  "name": "accomplice-theme",
  "version": "0.1.0",
  "brandDirection": {
    "summary": "Structured, editorial interface language using a tightly constrained Accomplice palette.",
    "notes": [
      "The shared color system is intentionally constrained to primary orange, black, white, and two greys.",
      "Avoid introducing semantic status colors or extra brand hues in the base theme."
    ]
  },
