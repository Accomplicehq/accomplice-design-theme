{
  "name": "@accomplice/shadcn-theme",
  "version": "0.1.0",
  "description": "Reusable Accomplice theme tokens and shadcn registry item for app projects.",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "build": "node scripts/build-theme.mjs",
    "build:ai-guide": "node scripts/build-ai-guide.mjs",
    "check": "node scripts/build-theme.mjs --check",
    "dev": "node scripts/dev-preview.mjs",
    "dev:vite": "vite",
    "build:vite": "vite build",
    "build:preview": "npm run build && vite build && npm run build:ai-guide",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.1.4",
    "vite": "^7.1.7"
  },
  "files": [
    "README.md",
    "registry.json",
    "registry",
    "styles",
    "tokens"
  ],
  "exports": {
    "./registry": "./registry/accomplice-theme.json",
    "./styles/accomplice.css": "./styles/accomplice.css",
    "./tokens": "./tokens/accomplice-theme.json"
  },
  "keywords": [
    "accomplice",
    "design-system",
    "shadcn",
    "theme",
    "tailwind"
  ],
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  }
}
